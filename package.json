{
  "name": "ysplan",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@ysplan/web",
    "dev:lan": "npm run dev --workspace @ysplan/web -- --hostname 0.0.0.0 --port 3001",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "check": "npm run lint && npm run typecheck && npm run build",
    "start:lan": "npm run start --workspace @ysplan/web -- --hostname 0.0.0.0 --port 3001",
    "db:generate": "npm run db:generate --workspace @ysplan/database",
    "db:validate": "npm run db:validate --workspace @ysplan/database",
    "db:push": "npm run db:push --workspace @ysplan/database",
    "db:migrate:dev": "npm run db:migrate:dev --workspace @ysplan/database",
    "db:studio": "npm run db:studio --workspace @ysplan/database"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
