{
  "name": "@ysplan/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@ysplan/auth": "file:../auth",
    "@ysplan/platform": "file:../platform",
    "@ysplan/tenant": "file:../tenant",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "prisma": "^7.5.0",
    "tsx": "^4.20.6"
  },
  "prisma": {
    "seed": "tsx ./src/auth-data-cli.ts seed-demo"
  },
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:validate": "prisma validate --schema ./prisma/schema.prisma",
    "db:push": "prisma db push --schema ./prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
    "db:studio": "prisma studio --schema ./prisma/schema.prisma",
    "db:seed:demo-auth-data": "tsx ./src/auth-data-cli.ts seed-demo",
    "db:import:file-store": "tsx ./src/auth-data-cli.ts import-file-store",
    "db:bootstrap:auth-data": "tsx ./src/auth-data-cli.ts bootstrap"
  }
}
